import { create } from 'zustand'
import { LoanConfig, LoanEvent, PaymentItem } from '../core/types'
import { generateSchedule } from '../core/calculator'

interface LoanState {
  config: LoanConfig | null
  events: LoanEvent[]
  schedule: PaymentItem[] | null

  setConfig: (config: LoanConfig) => void
  addEvent: (event: Omit<LoanEvent, 'id'>) => void
  updateEvent: (id: string, updates: Partial<Omit<LoanEvent, 'id' | 'type'>>) => void
  removeEvent: (id: string) => void
  calculate: () => void
}

let eventIdCounter = 0

export const useLoanStore = create<LoanState>((set, get) => ({
  config: null,
  events: [],
  schedule: null,

  setConfig: (config) => {
    set({ config })
    get().calculate()
  },

  addEvent: (event) => {
    const newEvent = { ...event, id: `event-${++eventIdCounter}` } as LoanEvent
    set((state) => ({ events: [...state.events, newEvent] }))
    get().calculate()
  },

  updateEvent: (id, updates) => {
    set((state) => ({
      events: state.events.map((e) =>
        e.id === id ? { ...e, ...updates } as LoanEvent : e
      ),
    }))
    get().calculate()
  },

  removeEvent: (id) => {
    set((state) => ({
      events: state.events.filter((e) => e.id !== id),
    }))
    get().calculate()
  },

  calculate: () => {
    const { config, events } = get()
    if (!config) {
      set({ schedule: null })
      return
    }

    const schedule = generateSchedule(config, events)
    set({ schedule })
  },
}))
